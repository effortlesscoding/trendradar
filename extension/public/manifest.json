{
  "manifest_version": 3,
  "name": "Reddit Research Tool",
  "version": "1.0.0",
  "description": "Scrape Reddit for YouTube content ideas in AI/CS space",
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": [
    "https://www.reddit.com/*",
    "https://old.reddit.com/*",
    "http://localhost:3457/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.reddit.com/*", "https://old.reddit.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
